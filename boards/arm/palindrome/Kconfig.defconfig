if BOARD_PALINDROME_LEFT

config ZMK_KEYBOARD_NAME
    default "Palindrome"

config ZMK_SPLIT_ROLE_CENTRAL
    default y

endif

if USB

config USB_NRFX
    default y

config USB_DEVICE_STACK
    default y

endif # USB

config BT_CTLR
    default BT

if BOARD_PALINDROME_LEFT || BOARD_PALINDROME_RIGHT

config ZMK_SPLIT
    default y
endif